data/
logs/*.log
logs/*.log.*

# IDE
.idea/
.vscode/
*.swp

# OS
Thumbs.db
desktop.ini
.DS_Store

# Secrets / credentials — NEVER commit real tokens
config/secrets.json
config/*.local.json
.env

# PyInstaller build output (rebuild from PokemonCollectionManager.spec)
build/
dist/
*.spec.bak
